# ─── WAJIB ───
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
GMGN_API_KEY=
JUPITER_API_KEY=

# ─── WALLET ───
SOLANA_PRIVATE_KEY=
TRADING_MODE=dry_run
BUY_AMOUNT_SOL=0.1
LIVE_MIN_SOL_RESERVE=0.02
JUPITER_SLIPPAGE_BPS=300

# ─── GATES ───
TOKEN_MAX_AGE_SEC=300
MIN_VOL_1M_USD=100000
MIN_MCAP_USD=100000
MIN_FEES_SOL=10
MAX_RUG_RATIO=0.3
SKIP_WASH_TRADING=true

# ─── TP / SL ───
TP1_PERCENT=100
TP1_SELL_PERCENT=50
TP2_PERCENT=150
TP2_SELL_PERCENT=50
TRAILING_PERCENT=30
SL_PERCENT=-50
MAX_HOLD_MINUTES=60

# ─── LLM ───
ENABLE_LLM=true
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=
LLM_MODEL=deepseek-v4-flash
LLM_TIMEOUT_MS=30000
LLM_MIN_CONFIDENCE=75

# ─── LIMITS ───
MAX_OPEN_POSITIONS=3
POSITION_CHECK_MS=5000
POLL_INTERVAL_MS=5000
GMGN_REQUEST_DELAY_MS=1200
